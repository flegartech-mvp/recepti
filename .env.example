# Public project settings. The anon key is safe to expose when RLS is enabled.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only owner allowlist.
OWNER_EMAIL=owner@example.com

# Test-only. Never set these on a production or preview deployment.
E2E_TEST_MODE=0

# Optional, server-only retailer catalogue feeds. Fixture, CSV, JSON, and
# manual workflows work without these values. Never prefix credentials with NEXT_PUBLIC_.
RETAILER_IMPORTS_ENABLED=0
RETAILER_IMAGE_IMPORT_ENABLED=0
RETAILER_ALLOWED_SOURCE_HOSTS=
RETAILER_SYNC_SECRET=
SPAR_SI_FEED_URL=
SPAR_SI_API_KEY=
HOFER_SI_FEED_URL=
HOFER_SI_API_KEY=
LIDL_SI_FEED_URL=
LIDL_SI_API_KEY=
